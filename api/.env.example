# ===========================================
# CONFIGURAÇÕES DO SISTEMA PM-IA
# ===========================================

# Servidor
PORT=3000
NODE_ENV=development

# JWT (autenticação)
JWT_SECRET=mude-esta-chave-em-producao-32chars

# ===========================================
# BANCO DE DADOS
# ===========================================

# PostgreSQL direto (ou Supabase)
DATABASE_URL=postgresql://postgres:senha@localhost:5432/pm_ia

# Supabase (se usar)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# IA - APIs
# ===========================================

# OpenAI (unica LLM usada)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# Modelos padrao
DEFAULT_MODEL_VOLUME=gpt-4.1-mini
DEFAULT_MODEL_QUALITY=gpt-4.1

# ===========================================
# CONFIGURAÇÕES DE IA
# ===========================================

# Threshold de confiança (0-100)
AI_CONFIDENCE_THRESHOLD=70

# Timeout de requisições IA (ms)
AI_REQUEST_TIMEOUT=30000

# ===========================================
# GOOGLE AGENDA (OAuth por usuário)
# ===========================================
# Credenciais do OAuth Client (Google Cloud Console > APIs & Services > Credentials).
# Habilite a "Google Calendar API" no projeto.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL do callback no BACKEND — deve estar cadastrada como "Authorized redirect URI"
# no OAuth Client. Ex (produção): https://api.seuapp.com/api/integrations/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# URL do FRONTEND para onde o usuário volta após conectar
APP_URL=http://localhost:5173

# ===========================================
# LOGS E MONITORAMENTO
# ===========================================

LOG_LEVEL=info
LOG_AI_INTERACTIONS=true

# Sentry (opcional)
SENTRY_DSN=

# ===========================================
# ORGANIZAÇÃO PADRÃO (para testes)
# ===========================================

DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
