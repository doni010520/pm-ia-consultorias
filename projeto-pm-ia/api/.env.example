# ===========================================
# CONFIGURAÇÕES DO SISTEMA PM-IA
# ===========================================

# Servidor
PORT=3000
NODE_ENV=development

# ===========================================
# BANCO DE DADOS
# ===========================================

# PostgreSQL direto (ou Supabase)
DATABASE_URL=postgresql://postgres:senha@localhost:5432/pm_ia

# Supabase (se usar)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# IA - APIs
# ===========================================

# OpenAI (para operações de alto volume)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# Anthropic Claude (para qualidade)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# Modelos padrão
DEFAULT_MODEL_VOLUME=gpt-4.1-mini
DEFAULT_MODEL_QUALITY=claude-sonnet-4-20250514

# ===========================================
# WHATSAPP - PROVIDER GENÉRICO
# ===========================================
# O sistema funciona com qualquer API de WhatsApp.
# Basta configurar a URL, token e provider abaixo.
#
# Providers suportados: evolution | uazapi | zapi | codechat | generic
#
# 1. Configure o webhook no seu provedor apontando para:
#    POST https://seu-dominio.com/webhook/whatsapp
#
# 2. Preencha as variáveis abaixo com os dados do seu provedor:

WHATSAPP_PROVIDER=evolution
WHATSAPP_API_URL=https://sua-api-whatsapp.com
WHATSAPP_API_TOKEN=seu_token_aqui
WHATSAPP_API_INSTANCE=nome_da_instancia

# Webhook secret (opcional — para validar requisições recebidas)
WEBHOOK_SECRET=

# ===========================================
# CONFIGURAÇÕES DE IA
# ===========================================

# Threshold de confiança (0-100)
AI_CONFIDENCE_THRESHOLD=70

# Timeout de requisições IA (ms)
AI_REQUEST_TIMEOUT=30000

# ===========================================
# LOGS E MONITORAMENTO
# ===========================================

LOG_LEVEL=info
LOG_AI_INTERACTIONS=true

# Sentry (opcional)
SENTRY_DSN=

# ===========================================
# ORGANIZAÇÃO PADRÃO (para testes)
# ===========================================

DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
