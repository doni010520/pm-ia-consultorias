      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2020, 500],
      "credentials": {
        "postgres": {
          "id": "postgres-pm",
          "name": "PostgreSQL PM"
        }
      }
    }
  ],
